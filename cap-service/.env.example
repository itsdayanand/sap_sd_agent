# Copy to .env for local development (cds watch reads this automatically
# via @sap/cds if you install dotenv, or export these in your shell)

SANDBOX_API_KEY=
SANDBOX_BASE_URL=https://sandbox.api.sap.com/s4hanacloud/sap/opu/odata/sap

# When true, every tool call returns mock fixture data immediately and
# never touches the sandbox at all (e.g. for an offline demo).
FORCE_MOCK=true

# When true (default), a failed live sandbox call falls back to mock
# fixture data instead of returning an error. Independent of FORCE_MOCK.
FALLBACK_ON_FAILURE=true
