# Copy to .env for local development

OPENAI_API_KEY=
LLM_MODEL=gpt-4o
LLM_BASE_URL=https://api.openai.com/v1

# URL of the CAP service's OData endpoint (see cap-service/.cdsrc.json / package.json)
# Local default matches `cds watch` default port (4004) and the service name
# defined in srv/sd-agent-service.cds
CAP_BASE_URL=http://localhost:4004/odata/v4/sd-agent
CAP_TIMEOUT_SECONDS=20.0

# Comma-separated list of allowed frontend origins in production,
# e.g. https://sd-agent-ui.cfapps.us10-001.hana.ondemand.com
# NOTE: if ENV=production and this is left as "*", the app refuses to start.
ALLOWED_ORIGINS=*

# Set to "production" on any non-localhost deployment. This enforces that
# ALLOWED_ORIGINS is not a wildcard.
ENV=development
